# AI
DASHSCOPE_API_KEY=your_dashscope_api_key
MAIN_MODEL=qwen3.5-omni-plus-2026-03-15
DECISION_TREE_MODEL=qwen3.5-omni-plus-2026-03-15
MULTIMODAL_MODEL=qwen3.5-omni-plus-2026-03-15
MODEL_TIMEOUT=40
SYNTHESIS_TIMEOUT=45
MULTIMODAL_TIMEOUT=80

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=1
LOG_LEVEL=INFO

# Database (PostgreSQL optional)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tcm_db
DB_USER=tcm_user
DB_PASSWORD=
# Optional legacy format (auto-parsed when DB_* is missing)
# DATABASE_URL=postgresql://tcm_user:password@localhost:5432/tcm_db

# Paths
KNOWLEDGE_DB_PATH=/opt/tcm-ai/knowledge_db

# OCR (optional)
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=

# Email / SMTP (163邮箱)
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USERNAME=your_email@163.com
SMTP_PASSWORD=your_smtp_auth_code
SMTP_FROM_NAME=TCM AI 中医智能诊疗
SMTP_USE_SSL=true

# Security / CORS
SECRET_KEY=replace_with_a_strong_secret
ALLOWED_ORIGINS=https://mxh0510.cn,https://www.mxh0510.cn,http://localhost:8000
DOMAIN=mxh0510.cn
