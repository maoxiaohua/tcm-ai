# TCM系统环境变量配置模板
# 推荐复制到 config/.env（也兼容项目根目录 .env）

# AI
DASHSCOPE_API_KEY=your_dashscope_api_key_here
MAIN_MODEL=qwen3.5-omni-plus-2026-03-15
DECISION_TREE_MODEL=qwen3.5-omni-plus-2026-03-15
MULTIMODAL_MODEL=qwen3.5-omni-plus-2026-03-15
MODEL_TIMEOUT=40
SYNTHESIS_TIMEOUT=45
MULTIMODAL_TIMEOUT=80

# 服务配置
HOST=0.0.0.0
PORT=8000
WORKERS=1
LOG_LEVEL=INFO

# 数据库配置（标准字段）
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tcm_db
DB_USER=tcm_user
DB_PASSWORD=
# 可选：历史格式（仅在 DB_* 缺失时自动解析）
# DATABASE_URL=postgresql://tcm_user:your_password@localhost:5432/tcm_db

# 路径
KNOWLEDGE_DB_PATH=/opt/tcm-ai/knowledge_db

# OCR（可选）
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=

# 安全 / CORS
SECRET_KEY=replace_with_a_strong_secret
ALLOWED_ORIGINS=https://mxh0510.cn,https://www.mxh0510.cn,http://localhost:8000
DOMAIN=mxh0510.cn

# 兼容旧变量名（可继续使用，但建议迁移到上面的标准字段）
# QWEN_API_KEY -> DASHSCOPE_API_KEY
# BAIDU_API_KEY -> BAIDU_OCR_API_KEY
# BAIDU_SECRET_KEY -> BAIDU_OCR_SECRET_KEY
# SERVER_HOST -> HOST
# SERVER_PORT -> PORT
# UVICORN_WORKERS -> WORKERS
# DATABASE_HOST/PORT/NAME/USER/PASSWORD -> DB_*
# DB_URL -> DATABASE_URL
# KNOWLEDGE_BASE_PATH -> KNOWLEDGE_DB_PATH
# CORS_ALLOWED_ORIGINS -> ALLOWED_ORIGINS
# APP_DOMAIN -> DOMAIN
