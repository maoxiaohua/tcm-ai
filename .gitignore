# ============================================
# TCM-AI 中医智能诊断系统 - Git 忽略规则
# ============================================

# --- 环境变量（包含 API Key、密码等敏感信息）---
.env
*.env
!.env.example

# --- Python 虚拟环境 ---
venv/
.venv/
env/
ENV/

# --- Python 缓存 ---
__pycache__/
*.pyc
*.pyo
*.pyd
*.py[cod]
*.so

# --- 日志文件 ---
logs/
*.log

# --- 数据库文件（包含用户数据，不应上传）---
*.sqlite
*.sqlite3
*.db
*.sqlite-*

# --- IDE 和编辑器 ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# --- 临时文件 ---
template_files/
*.tmp
*.temp

# --- 上传目录 ---
uploaded_images/
uploads/

# --- 备份文件 ---
backups/
*.backup
data/*_backup_*.sqlite

# --- 系统文件 ---
*.pid
.cache/
.claude/
.codex/